{
  "name": "myvault-workspace",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --dir apps/tauri tauri dev",
    "build": "pnpm --dir apps/tauri build",
    "typecheck": "pnpm --dir apps/tauri typecheck",
    "test": "pnpm --dir apps/tauri test",
    "check:rust": "cargo check --manifest-path apps/tauri/src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path apps/tauri/src-tauri/Cargo.toml",
    "tauri:info": "pnpm --dir apps/tauri tauri info"
  }
}
